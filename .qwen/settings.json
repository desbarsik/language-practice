{
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npx *)",
      "Bash(del *)",
      "Bash(git remote *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git config *)",
      "Bash(node *)",
      "Bash(dir *)",
      "Bash(yarn *)",
      "mcp__prompts.chat__search_prompts",
      "mcp__prompts.chat__get_prompt"
    ]
  },
  "mcpServers": {
    "shadcn-ui": {
      "command": "npx",
      "args": [
        "-y",
        "@jpisnice/shadcn-ui-mcp-server"
      ]
    },
    "prompts.chat": {
      "command": "npx",
      "args": [
        "-y",
        "prompts.chat",
        "mcp"
      ]
    }
  },
  "$version": 3
}
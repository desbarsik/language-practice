# AI Tutor API Configuration (OpenRouter)
# Get your key at: https://openrouter.ai/keys
VITE_AI_API_KEY=sk-or-v1-...

# OpenRouter API URL (default)
# VITE_AI_API_URL=https://openrouter.ai/api/v1

# Model: openai/gpt-oss-120b — стабильная, дешёвая (~$0.00004/ответ)
# Бесплатные альтернативы (могут быть rate-limited):
#   openai/gpt-oss-120b
VITE_AI_MODEL=openai/gpt-oss-120b
